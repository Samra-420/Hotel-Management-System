@model List<HotelManagementSystem.Models.Room>
@{
    ViewData["Title"] = "Rooms";
}
<h2><i class="fas fa-bed"></i> Rooms Management</h2>
<a href="/Rooms/Create" class="btn btn-primary mb-3">+ Add New Room</a>
@if (Model != null && Model.Any())
{
    <table class="table">
        <thead>
            <tr><th>Room No.</th><th>Type</th><th>Price/Night</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.RoomNumber</td>
                    <td>@room.RoomType</td>
                    <td>Rs. @room.PricePerNight</td>
                    <td>@(room.IsAvailable ? "<span class='badge-available'>Available</span>" : "<span class='badge-occupied'>Occupied</span>")</td>
                    <td>
                        <a href="/Rooms/Edit/@room.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a href="/Rooms/Delete/@room.Id" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No rooms added yet.</div>
}