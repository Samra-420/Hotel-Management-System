@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Hotel HMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1e3c72, #2a5298); min-height: 100vh; display: flex; align-items: center; }
        .login-card { background: white; border-radius: 10px; padding: 30px; box-shadow: 0 5px 20px rgba(0,0,0,0.2); max-width: 400px; margin: auto; }
        .login-header { text-align: center; margin-bottom: 30px; }
        .login-header h2 { color: #1e3c72; }
        .btn-login { background: #1e3c72; color: white; width: 100%; padding: 10px; }
        .btn-login:hover { background: #2a5298; }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-card">
            <div class="login-header">
                <i class="fas fa-hotel fa-3x" style="color: #1e3c72;"></i>
                <h2>Hotel HMS</h2>
                <p>Sign in to continue</p>
            </div>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <form method="post" action="/Account/Login">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-login">Login</button>
            </form>
            <hr />
            <div class="text-center"><small>Default: admin / admin123</small></div>
        </div>
    </div>
</body>
</html>